{
  "name": "@kataokahiroki/lint-config-react",
  "version": "1.0.0",
  "description": "Shared ESLint and Prettier configuration for React + TypeScript projects",
  "type": "module",
  "license": "MIT",
  "author": "kataokahiroki",
  "keywords": [
    "eslint",
    "prettier",
    "config",
    "react",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "eslint.config.mjs",
    "eslint.config.d.mts",
    "prettier.config.mjs",
    "prettier.config.d.mts"
  ],
  "exports": {
    "./eslint": {
      "types": "./eslint.config.d.mts",
      "default": "./eslint.config.mjs"
    },
    "./prettier": {
      "types": "./prettier.config.d.mts",
      "default": "./prettier.config.mjs"
    }
  },
  "dependencies": {
    "@eslint/js": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-functional": "^8.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prefer-arrow-functions": "^3.6.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-storybook": "^0.11.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "typescript-eslint": "^8.22.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
